{
  "name": "peariscope-pear",
  "version": "0.2.0",
  "description": "Peariscope P2P networking layer using Pear/Hyperswarm",
  "main": "index.js",
  "pear": {
    "name": "peariscope",
    "type": "terminal",
    "stage": {
      "ignore": [
        "test-*.js",
        "addons-darwin/",
        "addons/",
        ".git",
        "node_modules/@hyperswarm/testnet",
        "node_modules/bare-bundle"
      ]
    }
  },
  "imports": {
    "node:crypto": {
      "bare": "hypercore-crypto",
      "default": "crypto"
    },
    "node:fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "node:os": {
      "bare": "bare-os",
      "default": "os"
    },
    "node:path": {
      "bare": "bare-path",
      "default": "path"
    },
    "node:url": {
      "bare": "bare-url",
      "default": "url"
    },
    "node:net": {
      "bare": "bare-tcp",
      "default": "net"
    },
    "node:events": {
      "bare": "bare-events",
      "default": "events"
    }
  },
  "scripts": {
    "dev": "node index.js",
    "proto": "pbf protocol/messages.proto > lib/messages.js"
  },
  "dependencies": {
    "b4a": "^1.6.0",
    "bare-events": "^2.8.2",
    "bare-fs": "^4.5.5",
    "bare-ipc": "^1.1.1",
    "bare-link": "^3.0.0",
    "bare-os": "^3.8.0",
    "bare-pack": "^1.5.1",
    "bare-path": "^3.0.0",
    "bare-pipe": "^4.1.3",
    "bare-process": "^4.3.0",
    "bare-stream": "^2.8.1",
    "bare-tcp": "^2.2.7",
    "bare-url": "^2.3.2",
    "compact-encoding": "^2.12.0",
    "corestore": "^7.9.1",
    "hypercore-crypto": "^3.4.0",
    "hyperdht": "^6.29.5",
    "hyperdrive": "^13.3.0",
    "hyperswarm": "^4.7.0",
    "protobufjs": "^7.2.0",
    "random-access-memory": "^6.2.1",
    "safety-catch": "^1.0.3",
    "sodium-native": "^5.0.10"
  },
  "devDependencies": {
    "@hyperswarm/testnet": "^3.1.4",
    "bare-bundle": "^1.10.0"
  }
}
