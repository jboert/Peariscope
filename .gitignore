# Build artifacts
apple/build/
apple/.build/
apple/.swiftpm/
*.xcarchive

# Dependencies
pear/node_modules/

# Bundles (regenerated from worklet.js). The dotted variant (worklet.bundle.ios)
# and hyphenated variant (worklet-ios.bundle) both need to be covered — prior
# rename-drifts left orphan files that weren't matched by the short glob.
pear/*.bundle
pear/*.bundle.*
pear/worklet-*.bundle

# Xcode
*.xcuserstate
xcuserdata/
DerivedData/

# OS files
.DS_Store
._*
Thumbs.db

# Binary outputs
*.ipa
*.zip

# Derived/temp images
logo1_cropped.png
logo1_green_bg.png

# Development notes (not docs)
PEAR.md
PLAN.md
SUGGESTIONS.md

# Test files
test-bare.swift
test/

# Linux build artifacts
linux/build/

# Claude
.claude/
